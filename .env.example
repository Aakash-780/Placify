# InsForge Configuration
# Get these values from your InsForge dashboard: https://insforge.dev
VITE_INSFORGE_BASE_URL=https://your-project-id.region.insforge.app
VITE_INSFORGE_ANON_KEY=your_insforge_anonymous_key_here

# Google Gemini API key (for AI Student Explorer / ATS Resume Analyzer)
# Get yours free at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Grok (xAI) API key for AI fallback (optional)
VITE_GROK_API_KEY=your_grok_api_key_here


# Local AI ATS / Ollama Configuration
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.2
VITE_USE_AI_ATS=true


